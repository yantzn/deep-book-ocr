# local | gcp
APP_ENV=local
LOG_LEVEL=INFO

# GCP
GCP_PROJECT_ID=deep-book-ocr
GCP_LOCATION=us-central1

# required
OUTPUT_BUCKET=deep-book-ocr-output-xxxxxx

# Gemini
MODEL_NAME=gemini-2.5-flash
CHUNK_SIZE=10

# local runner input（Firestoreに登録済みのジョブID）
LOCAL_JOB_ID=replace-with-existing-job-id

# optional: トレースヘッダを固定したい場合のみ設定
# LOCAL_TRACE_CONTEXT=local-trace-id/0;o=1
