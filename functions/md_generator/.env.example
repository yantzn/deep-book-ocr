# local | gcp
APP_ENV=local
LOG_LEVEL=INFO

# GCP
GCP_PROJECT_ID=deep-book-ocr

# required
TEMP_BUCKET=deep-book-ocr-temp-xxxxxx
OUTPUT_BUCKET=deep-book-ocr-output-xxxxxx
FIRESTORE_JOBS_COLLECTION=ocr_jobs

# Gemini
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_API_KEY=replace-with-gemini-api-key
ENABLE_GEMINI_POLISH=true
GEMINI_MAX_INPUT_CHARS=120000
GEMINI_TIMEOUT_SEC=60
# optional: 既定は Gemini API v1beta
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# GCS I/O tuning (optional)
GCS_DOWNLOAD_TIMEOUT_SEC=30
GCS_UPLOAD_TIMEOUT_SEC=30
GCS_EXISTS_TIMEOUT_SEC=10
GCS_DOWNLOAD_MAX_ATTEMPTS=3
GCS_DOWNLOAD_BASE_SLEEP_SEC=1.0

# Firestore tuning (optional)
FIRESTORE_TIMEOUT_SEC=20

# local runner input（Firestoreに登録済みのジョブID）
LOCAL_JOB_ID=replace-with-existing-job-id

# optional: トレースヘッダを固定したい場合のみ設定
# LOCAL_TRACE_CONTEXT=local-trace-id/0;o=1
