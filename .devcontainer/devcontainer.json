{
  "name": "deep-book-ocr",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "remoteUser": "vscode",
  "postCreateCommand": "python --version && terraform -version && gcloud --version",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "hashicorp.terraform",
        "googlecloudtools.cloudcode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "terraform.languageServer.enable": true
      }
    }
  }
}
